// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// MASTER DATA
// =======================

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Akan di-hash untuk MVP
  name      String
  email     String?  // Email untuk fitur lupa password
  role      String   // "ADMIN", "SPV", "AFA", "FO", "INTERN"
  phone     String?  // Nomor WhatsApp (digunakan untuk notifikasi WAHA)
  isActive  Boolean  @default(true)
  
  // Self-Relation untuk AFA -> FO
  afaId     String?
  afa       User?    @relation("AfaToFo", fields: [afaId], references: [id])
  fos       User[]   @relation("AfaToFo")

  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi Transaksional
  ledgers           Ledger[]
  sampleLedgers     SampleLedger[]
  requestsAsFo      Request[]  @relation("FoRequests")
  requestsAsAfa     Request[]  @relation("AfaApprovals")
  stockOpnames      StockOpname[]

  // Laporan Aktivitas
  customerBehaviors CustomerBehavior[]
  visitKios         VisitKios[]
  farmerGatherings  FarmerGathering[]
  visitCompanies    VisitCompany[]
  spotDemplot       SpotDemplot[]

  // Notifikasi
  notifications     Notification[]
}

model Store {
  id           String   @id @default(cuid())
  accurateId   String?  @unique  // customer no dari Accurate
  name         String
  code         String?           // kode toko / no customer
  address      String?
  latitude     Float?
  longitude    Float?
  phone        String?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model KpiTarget {
  id              String   @id @default(cuid())
  areaId          String?  // null = "Tanpa Area" (target global/unassigned)
  area            Area?    @relation(fields: [areaId], references: [id])
  
  month           Int      // 1-12
  year            Int
  
  targetDemoPlot  Int      @default(0)
  targetVisitKios Int      @default(0)
  targetGathering Int      @default(0)
  targetCompany   Int      @default(0)
  targetBehavior  Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([areaId, month, year])
}

model Area {
  id         String       @id @default(cuid())
  name       String
  users      User[]
  coverages  AreaCoverage[]
  kpiTargets KpiTarget[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model AreaCoverage {
  id            String   @id @default(cuid())
  areaId        String
  area          Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  kabupatenName String   // nama kabupaten/kota lowercase & normalized
  createdAt     DateTime @default(now())

  @@unique([areaId, kabupatenName])
}

// Permintaan pembuatan akun dari calon user (self-register)
model AccountRequest {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   // "AFA", "FO"
  email     String?  // Email dari calon user
  areaName  String?  // Area yang diminta (nama teks)
  afaName   String?  // Nama AFA supervisor (untuk FO)
  notes     String?  // Catatan dari calon user
  status    String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  rejectReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Konfigurasi sistem (WAHA, nomor WA per role, dll)
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique  // "waha_base_url", "waha_api_key", "waha_session", "wa_spv", "wa_fam", "wa_whm"
  value     String
  label     String?  // Label user-friendly untuk UI admin
  updatedAt DateTime @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  code            String?
  accurateId      String?  @unique  // no_barang / SKU dari Accurate Online
  name            String
  description     String?
  unit            String   // Satuan kemasan: PCS, Btl, Bks, Box, Sak, gl, Pack, Rol
  unitGramasi     String?  // Satuan isi per kemasan: "ml" atau "gr"
  gramasiPerUnit  Float?   // Volume/berat per kemasan, misal 500 (artinya 500ml/Btl)
  spvStock        Float?   // Stok SPV dari Accurate (dalam satuan kemasan)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ledgers           Ledger[]
  sampleLedgers     SampleLedger[]
  requestDetails    RequestDetail[]
  demoPlotDetails   DemoPlotDetail[]
  opnameDetails     OpnameDetail[]
  spotDemplotDetails SpotDemplotDetail[]
}

model Farmer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  area      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests  Request[]
  demoPlots DemoPlot[]
}

// =======================
// CORE ENGINE: LEDGER
// =======================

model Ledger {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  transactionType String   // "STOCK_IN_GUDANG", "TRANSFER_TO_FO", "RECEIVE_FROM_AFA", "USAGE_DEMOPLOT", "DIRECT_USAGE_AFA", "ADJUSTMENT_PLUS", "ADJUSTMENT_MINUS"
  quantity        Float    // Nilai bisa positif (masuk) atau negatif (keluar)
  referenceId     String?  // ID dari Request / DemoPlot / StockOpname
  snapshotAreaId  String?  // areaId user saat transaksi terjadi
  notes           String?
  
  createdAt       DateTime @default(now())
}

// =======================
// TRANSACTIONAL MODELS
// =======================

model Request {
  id             String   @id @default(cuid())
  foId           String
  fo             User     @relation("FoRequests", fields: [foId], references: [id])
  afaId          String?
  afa            User?    @relation("AfaApprovals", fields: [afaId], references: [id])
  farmerId       String?
  farmer         Farmer?  @relation(fields: [farmerId], references: [id])
  
  area           String?
  snapshotAreaId String?  // areaId saat transaksi dibuat (tidak berubah meski user rotasi)
  commodity      String?
  cbReference    String?
  problem        String?
  plan           String?
  status         String   @default("SUBMITTED") // "SUBMITTED", "APPROVED_SPV", "APPROVED_FAM", "APPROVED_WHM", "APPROVED", "REJECTED", "DEMO_PLOT_SELESAI"
  rejectReason   String?  // Keterangan/alasan penolakan (diisi oleh approver saat reject)
  accurateInvoiceNo String? // Nomor faktur dari Accurate Online (terisi saat SPV terima stok)
  warehouseSource String? @default("MAIN") // "MAIN" (Accurate) | "SAMPLE" (Gudang Sampel SPV)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  details        RequestDetail[]
  demoPlots      DemoPlot[]
}

model SampleLedger {
  id              String   @id @default(cuid())
  userId          String   // SPV pemilik gudang sampel
  user            User     @relation(fields: [userId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Float    // + masuk (SAMPLE_IN), - keluar (SAMPLE_OUT)
  transactionType String   // "SAMPLE_IN" | "SAMPLE_OUT"
  notes           String?
  referenceId     String?  // requestId jika keluar ke AFA
  createdAt       DateTime @default(now())
}

model RequestDetail {
  id             String   @id @default(cuid())
  requestId      String
  request        Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  
  qtyRequested   Float
  qtyApproved    Float?
  requestUnit    String?  // Satuan saat diajukan (ml, gr, Btl, dll) — agar tampilan konsisten
}

model DemoPlot {
  id             String   @id @default(cuid())
  requestId      String?
  request        Request? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  farmerId       String?
  farmer         Farmer?  @relation(fields: [farmerId], references: [id])
  
  date           DateTime
  area           String?
  snapshotAreaId String?  // areaId FO/user saat demplot dibuat
  commodity      String?
  cropAgeDays    Int?     // umur tanaman dalam HST (hari setelah tanam)
  landSize       Float?
  landSizeUnit   String?  // "ha" atau "m2"
  resultNotes    String?
  photos         String?  // JSON stringified array of URLs
  latitude       Float?
  longitude      Float?
  isFinalSession Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  details        DemoPlotDetail[]
}

model DemoPlotDetail {
  id             String   @id @default(cuid())
  demoPlotId     String
  demoPlot       DemoPlot @relation(fields: [demoPlotId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  
  actualUsage          Float
  usedFarmerProduct    Boolean  @default(false) // true = produk milik petani, tidak memotong stok user
}

model StockOpname {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  status         String   @default("SUBMITTED") // "SUBMITTED", "APPROVED", "REJECTED"
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  details        OpnameDetail[]
}

model OpnameDetail {
  id             String   @id @default(cuid())
  opnameId       String
  opname         StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  
  systemStock    Float
  physicalStock  Float
  variance       Float
  notes          String?
}

// =======================
// ACTIVITY REPORTS
// =======================

model CustomerBehavior {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  
  snapshotAreaId String?  // areaId user saat record dibuat
  farmerName     String
  age            String?
  phone          String?
  address        String?
  district       String?
  commodity      String?
  reasonChoice   String?
  constraints    String?
  optTypes       String?  // JSON Array: ["Hama", "Penyakit", "Gulma"]
  optDetails     String?  // JSON Array: ["Wereng", "Kutu", "Jamur"]
  usedProducts   String?  // Biotis/Non-biotis
  buyLocation    String?  // Kios tempat membeli
  buyReason      String?
  references     String?
  notes          String?
  photos         String?  // URL foto dokumentasi (JSON Array)
  totalLandArea     Float?   // Luas lahan total petani
  totalLandAreaUnit String?  // "ha" atau "m2"
  latitude       Float?
  longitude      Float?
  
  createdAt      DateTime @default(now())
}

model VisitKios {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  snapshotAreaId String?  // areaId user saat visit dibuat
  
  kiosName       String
  activityDetail String?
  visitResult    String?
  notes          String?
  photos         String?  // URL foto dokumentasi (JSON Array)
  
  createdAt      DateTime @default(now())
}

model FarmerGathering {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  snapshotAreaId String?  // areaId user saat gathering dibuat
  
  address        String?
  district       String?
  leaderName     String?
  phone          String?
  activityDetail String?
  cost           Float?
  costDetail     String?
  photos         String?  // URL foto dokumentasi (JSON Array)
  
  createdAt      DateTime @default(now())
}

model VisitCompany {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  snapshotAreaId   String?  // areaId user saat visit dibuat
  
  companyName      String
  district         String?
  address          String?
  picName          String?
  picPosition      String?
  picPhone         String?
  landArea         String?
  commodities      String?  // JSON Array: ["Padi", "Jagung"]
  products         String?
  procurementDate  DateTime?
  paymentTerm      String?  // "COD", "CBD", "TOP<30 HARI", "TOP>30 HARI"
  photos           String?  // URL foto dokumentasi (JSON Array)
  
  createdAt        DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String   
  link      String?
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())
}

model SpotDemplot {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  snapshotAreaId    String?  // areaId user saat spot demplot dibuat
  districtDesa      String?
  districtKec       String?
  districtKab       String?
  weeds             String?  // JSON Array or string
  date              DateTime
  observationResult String?
  latitude          Float?
  longitude         Float?
  photos            String?  // JSON Array of URLs
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  details           SpotDemplotDetail[]
}

model SpotDemplotDetail {
  id             String      @id @default(cuid())
  spotDemplotId  String
  spotDemplot    SpotDemplot @relation(fields: [spotDemplotId], references: [id], onDelete: Cascade)
  productId      String
  product        Product     @relation(fields: [productId], references: [id])
  usage                Float
  usedFarmerProduct    Boolean  @default(false) // true = produk milik petani, tidak memotong stok user
}
